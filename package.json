{
  "name": "streamthenown",
  "version": "0.1.0",
  "description": "Stream, then own — find purchase links for music on YouTube Music.",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "stylelint": "stylelint \"public/styles/**/*.css\"",
    "stylelint:fix": "stylelint \"public/styles/**/*.css\" --fix",
    "audit": "npm audit --audit-level=moderate",
    "lockfile-lint": "lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https",
    "sbom": "npm sbom --sbom-format cyclonedx",
    "validate": "npm run typecheck && npm run lint && npm run stylelint && npm run format:check && npm run knip && npm run audit && npm run lockfile-lint && npm run test && npm run build",
    "zip": "npm run build && sh scripts/zip.sh",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sillot/StreamThenOwn.git"
  },
  "keywords": [
    "chrome-extension",
    "youtube-music",
    "music"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Sillot/StreamThenOwn/issues"
  },
  "homepage": "https://github.com/Sillot/StreamThenOwn#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.37",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-no-unsanitized": "^4.1.2",
    "eslint-plugin-regexp": "^3.0.0",
    "jsdom": "^28.1.0",
    "knip": "^5.47.0",
    "lint-staged": "^16.0.0",
    "lockfile-lint": "^5.0.0",
    "prettier": "^3.5.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.28.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}

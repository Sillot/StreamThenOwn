{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.1.0",
  "default_locale": "en",
  "permissions": ["storage"],
  "host_permissions": ["https://musicbrainz.org/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "StreamThenOwn"
  },
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["content/index.js"],
      "css": ["styles/sto.css", "styles/youtube.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://open.spotify.com/*"],
      "js": ["content/index.js"],
      "css": ["styles/sto.css", "styles/spotify.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://music.apple.com/*"],
      "js": ["content/index.js"],
      "css": ["styles/sto.css", "styles/apple.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://music.youtube.com/*", "*://open.spotify.com/*", "*://music.apple.com/*"]
    }
  ]
}
